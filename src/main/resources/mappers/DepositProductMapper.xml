<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.sound.deposit.dao.DepositProductDAO">
    
    <!-- 
        모든 예금 상품 조회
        - DEPOSIT_PRODUCT_TBL의 모든 레코드를 조회
        - product_id 기준 내림차순 정렬
    -->
    <select id="findAll" resultType="com.boot.sound.deposit.dto.DepositProductDTO">
        SELECT * FROM DEPOSIT_PRODUCT_TBL
        ORDER BY product_id DESC
    </select>

    <!-- 
        ID로 예금 상품 조회
        - 특정 product_id에 해당하는 예금 상품 조회
        - 파라미터: id (Long)
    -->
    <select id="findById" resultType="com.boot.sound.deposit.dto.DepositProductDTO">
        SELECT * FROM DEPOSIT_PRODUCT_TBL
        WHERE product_id = #{id}
    </select>

    <!-- 
        예금 상품 생성
        - 새로운 예금 상품을 DEPOSIT_PRODUCT_TBL에 추가
        - 파라미터: DepositProductDTO 객체
        - 자동 생성되는 필드(created_at, updated_at)는 제외
    -->
    <insert id="create" parameterType="com.boot.sound.deposit.dto.DepositProductDTO">
        INSERT INTO DEPOSIT_PRODUCT_TBL (
            product_name,
            product_type,
            interest_rate,
            min_amount,
            max_amount,
            term_months,
            description
        ) VALUES (
            #{productName},
            #{productType},
            #{interestRate},
            #{minAmount},
            #{maxAmount},
            #{termMonths},
            #{description}
        )
    </insert>

    <!-- 
        예금 상품 수정
        - 기존 예금 상품의 정보를 업데이트
        - 파라미터: DepositProductDTO 객체
        - product_id를 기준으로 업데이트할 레코드 지정
    -->
    <update id="update" parameterType="com.boot.sound.deposit.dto.DepositProductDTO">
        UPDATE DEPOSIT_PRODUCT_TBL
        SET
            product_name = #{productName},
            product_type = #{productType},
            interest_rate = #{interestRate},
            min_amount = #{minAmount},
            max_amount = #{maxAmount},
            term_months = #{termMonths},
            description = #{description}
        WHERE product_id = #{productId}
    </update>

    <!-- 
        예금 상품 삭제
        - 특정 product_id에 해당하는 예금 상품 삭제
        - 파라미터: id (Long)
    -->
    <delete id="delete" parameterType="long">
        DELETE FROM DEPOSIT_PRODUCT_TBL
        WHERE product_id = #{id}
    </delete>

</mapper> 